        .detail-info-list { list-style: none; margin: 0; padding: 0; border-bottom: 1px solid #eee; }
        .detail-info-list li { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px dotted #e0e0e0; font-size: 0.9rem; }
        .detail-info-list li .info-label { display: flex; align-items: center; gap: 8px; font-weight: 600; color: #37474f; }
        .detail-info-list li .info-icon { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.8rem; }
        .detail-info-list li .info-value { font-weight: 600; color: #263238; font-size: 0.85rem; }

        .detail-actions { padding: 12px; }
