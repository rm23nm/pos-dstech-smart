        .titik-grid { display: flex; flex-wrap: wrap; gap: 8px; }

        .titik-box {
            width: 90px; height: 90px;
            border-radius: 10px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            font-size: 1.8rem; font-weight: 700; color: #fff;
            cursor: pointer; border: 3px solid transparent;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 3px 7px rgba(0,0,0,0.22);
            position: relative;
        }
        .titik-box:hover { transform: scale(1.1); }
        .titik-box.active-selected { border-color: #fff; box-shadow: 0 0 0 3px rgba(255,255,255,0.7); }

        .status-0  { background: linear-gradient(135deg, #2e7d32, #43a047); }
        .status-1  { background: linear-gradient(135deg, #b71c1c, #e53935); }
