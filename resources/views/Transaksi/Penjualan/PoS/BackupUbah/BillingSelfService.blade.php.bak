        .status-99 { background: linear-gradient(135deg, #e65100, #fb8c00); }
        .status-n1 { background: linear-gradient(135deg, #f57f17, #fdd835); }

        .table-timer { font-size: 0.85rem; margin-top: 5px; font-family: monospace; background: rgba(0,0,0,0.2); padding: 2px 5px; border-radius: 4px; }
