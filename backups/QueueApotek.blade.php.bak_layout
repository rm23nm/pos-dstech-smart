</div>

<audio id="audio-bell" src="{{ asset('assets/audio/airport_bell.mp3') }}" preload="auto"></audio>

<script src="https://www.youtube.com/iframe_api"></script>
<script>
  // === JAM ===
  setInterval(() => {
    const d = new Date();
    document.getElementById('clock').innerText = d.toLocaleTimeString('id-ID');
  }, 1000);

  // === MEDIA PLAYER ===
  const banners = document.querySelectorAll('#media-container > div');
  let index = 0;
  let autoSlideInterval = null;
  let ytPlayers = [];

  function activateSlide(i) {
    if(banners.length === 0) return;
    banners.forEach((b, j) => b.classList.toggle('active', j === i));
    const iframe = banners[i].querySelector('iframe');
    if (iframe && ytPlayers[i]) ytPlayers[i].playVideo();
  }

  function nextSlide() {
    if(banners.length === 0) return;
    index = (index + 1) % banners.length;
    activateSlide(index);
  }

  function startAutoSlide() {
    clearInterval(autoSlideInterval);
    autoSlideInterval = setInterval(() => {
      if(banners.length === 0) return;
      const active = banners[index];
      if (!active.classList.contains('video-banner')) {
        nextSlide();
      }
    }, 5000);
  }

  function onYouTubeIframeAPIReady() {
    document.querySelectorAll('.youtube-frame').forEach((iframe, i) => {
      ytPlayers[i] = new YT.Player(iframe, {
        events: {
          'onReady': () => {
            if (i === 0) {
              activateSlide(index);
              startAutoSlide();
            }
          },
          'onStateChange': (event) => {
            if (event.data === YT.PlayerState.ENDED) {
              nextSlide();
            }
          }
        }
      });
    });
  }

  if(banners.length > 0 && !document.querySelector('.youtube-frame')) {
      startAutoSlide();
  }

  // === QUEUE LOGIC ===
  let spokenCache = [];

  function updateTables(data) {
    let diramuHTML = '';
    data.sedangDiramu.forEach(row => {
        let name = (row.NamaPelanggan && row.NamaPelanggan.toUpperCase() !== 'CASH') ? row.NamaPelanggan : row.NoTransaksi.substring(row.NoTransaksi.length - 4);
        diramuHTML += `<div class="queue-item">${name}</div>`;
    });
    document.getElementById('list-diramu').innerHTML = diramuHTML || '<div class="text-center text-muted mt-4">Belum ada data</div>';

    let siapHTML = '';
    let newlyReady = [];
    
    data.siapDiambil.forEach(row => {
        let name = (row.NamaPelanggan && row.NamaPelanggan.toUpperCase() !== 'CASH') ? row.NamaPelanggan : row.NoTransaksi.substring(row.NoTransaksi.length - 4);
        siapHTML += `<div class="queue-item ready-item">${name}</div>`;
        
        if (!spokenCache.includes(row.NoTransaksi)) {
            newlyReady.push(name);
            spokenCache.push(row.NoTransaksi);
        }
    });
    document.getElementById('list-siap').innerHTML = siapHTML || '<div class="text-center text-muted mt-4">Belum ada data</div>';

    if (newlyReady.length > 0) {
        let text = "Panggilan untuk antrean atas nama " + newlyReady.join(", dan ") + ". Obat anda telah siap untuk diambil. Terima kasih.";
        
        let bell = document.getElementById('audio-bell');
        if(bell) {
            bell.play().catch(e => console.log('Audio error:', e));
        }
        setTimeout(() => {
            responsiveVoice.speak(text, "Indonesian Female", {rate: 0.85});
        }, 1500);
    }
  }

  function fetchQueueData() {
    const RecordOwnerID = "<?php echo $idE ?>";
    $.ajax({
      url: "{{ route('queue-apotek-getData') }}",
      method: 'POST',
      headers: { 'X-CSRF-TOKEN': '{{ csrf_token() }}' },
      data: { RecordOwnerID },
      success: updateTables,
      error: function(xhr) {
        console.error("Gagal ambil data antrian apotek:", xhr);
      }
    });
  }

  function toggleFullscreen() {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen();
    } else {
      if (document.exitFullscreen) {
        document.exitFullscreen();
      }
    }
  }

  // Auto Refresh
  setInterval(fetchQueueData, 5000);
  fetchQueueData();
</script>
</body>
</html>
